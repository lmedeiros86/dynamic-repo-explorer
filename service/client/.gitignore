# Navigate to client directory
cd ../client  # Go back to root first, then to client

# Create client .gitignore
cat > .gitignore << 'EOF'
# Dependencies
node_modules/

# Environment variables
.env.local
.env.development.local
.env.test.local
.env.production.local

# Build outputs
build/
dist/
out/

# Coverage
coverage/

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# IDE files
.vscode/
.idea/
*.swp
*.swo
*~

# Testing
coverage/

# Production build artifacts
*.zip
*.tar.gz

# React specific
public/build/
public/dist/

# Temporary files
tmp/
temp/
EOF
