{
  "name": "dynamic-repo-explorer-service",
  "version": "1.0.0",
  "description": "Backend service for Dynamic Repository Explorer",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "test": "jest --config=jest.config.cjs --detectOpenHandles --forceExit",
    "test:watch": "jest --config=jest.config.cjs --watch",
    "test:coverage": "jest --config=jest.config.cjs --coverage"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/dotenv": "^6.1.1",
    "@types/express": "^5.0.3",
    "@types/jest": "^29.5.14",
    "@types/nock": "^10.0.3",
    "@types/node": "^24.7.2",
    "@types/supertest": "^6.0.3",
    "@types/testing-library__jest-dom": "^5.14.9",
    "dotenv": "^17.2.3",
    "jest": "^29.7.0",
    "module-alias": "^2.2.3",
    "nock": "^14.0.10",
    "supertest": "^6.3.3",
    "ts-jest": "^29.4.5",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  },
  "_moduleAliases": {
    "@": "./src"
  },
  "dependencies": {
    "@types/express-rate-limit": "^5.1.3",
    "@types/module-alias": "^2.0.4",
    "@types/node-cache": "^4.1.3",
    "axios": "^1.12.2",
    "body-parser": "^2.2.0",
    "cors": "^2.8.5",
    "envalid": "^8.1.0",
    "express": "^5.1.0",
    "express-rate-limit": "^8.1.0",
    "node-cache": "^5.1.2",
    "zod": "^4.1.12"
  }
}
