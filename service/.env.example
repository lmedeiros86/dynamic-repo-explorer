# =================================
# Server Configuration
# =================================
# The port on which the server will run
PORT=3001

# Application environment (development, test, production)
NODE_ENV=development

# =================================
# CORS Configuration
# =================================
# Comma-separated list of allowed origins (no trailing slashes)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# =================================
# GitHub API Configuration
# =================================
# Generate at: https://github.com/settings/tokens
# Required scopes: repo, user
GITHUB_TOKEN=your_github_token_here

# Rate limiting (requests per hour)
GITHUB_RATE_LIMIT=5000

# =================================
# Logging
# =================================
# Log level (error, warn, info, debug, trace)
LOG_LEVEL=debug

# Enable/disable request logging
ENABLE_REQUEST_LOGGING=true

# =================================
# Cache Configuration
# =================================
# Enable/disable caching
CACHE_ENABLED=true

# Cache TTL in seconds
CACHE_TTL=3600

# =================================
# Security
# =================================
# Secret key for signing cookies/sessions
SESSION_SECRET=your_session_secret_here

# Enable/disable security headers
SECURITY_HEADERS_ENABLED=true

# =================================
# API Configuration
# =================================
# Base API URL (without trailing slash)
API_BASE_URL=/api/v1

# Enable/disable API documentation
API_DOCS_ENABLED=true

# =================================
# Development Settings
# =================================
# Enable/disable debug mode
DEBUG=true

# Enable/disable stack traces in responses
SHOW_STACK_TRACE=false